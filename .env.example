# Shared runtime settings
ENVIRONMENT=local
LOG_LEVEL=INFO
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=triage
POSTGRES_USER=triage
POSTGRES_PASSWORD=triage
DATABASE_URL=postgresql://triage:triage@postgres:5432/triage

# Service URLs used by gateway / runtime
TRIAGE_ENGINE_URL=http://triage-engine:8101
SAFETY_ENGINE_URL=http://safety-engine:8102
HANDOFF_ROUTER_URL=http://handoff-router:8103
DOCUMENTATION_URL=http://documentation:8104

# TODO(credentials): wire Twilio credentials for voice ingress
TWILIO_ACCOUNT_SID=TODO
TWILIO_AUTH_TOKEN=TODO
TWILIO_PHONE_NUMBER=TODO
TWILIO_WHATSAPP_SENDER=whatsapp:+14155238886
TWILIO_CALLBACK_BASE_URL=https://example.ngrok-free.app
TWILIO_PUBLIC_WEBHOOK_BASE_URL=https://example.ngrok-free.app
TWILIO_WHATSAPP_SANDBOX_MODE=true
TWILIO_VALIDATE_SIGNATURES=true
TWILIO_WHATSAPP_ROUTING_MODE=auto
TWILIO_WHATSAPP_TEMPLATE_DUE_REMINDER_SID=
TWILIO_WHATSAPP_TEMPLATE_OVERDUE_FOLLOWUP_SID=

# Medication transport adapter
MEDICATION_TRANSPORT_PROVIDER=mock

# Sandbox pilot safeguards
MEDICATION_PILOT_MODE=false
MEDICATION_PILOT_ALLOWED_PATIENT_IDS=
MEDICATION_PILOT_ALLOWED_NUMBERS=
MEDICATION_PILOT_ALLOWED_CHANNELS=mock_text,whatsapp
MEDICATION_PILOT_MAX_SENDS_PER_DAY=100

